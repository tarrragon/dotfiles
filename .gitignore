# Secrets
*.pem
*.key
id_*
*.env
.env*
# 但 .env.example 是佔位模板（無真值）、必須進 repo：deploy.sh 依賴它 scaffold .env
!.env.example

# OS
.DS_Store
Thumbs.db

# Caches
*.zwc
.zcompdump*
.zsh_history

# Machine-specific (create locally, don't commit)
zsh/.config/zsh/local.zsh

# Homebrew lock
Brewfile.lock.json

# Editor
*.swp
*.swo
*~

# App runtime writes through folded stow symlinks (caelestia/btop write into their config dirs)
caelestia/.config/caelestia/monitors/
btop/.config/btop/themes/
