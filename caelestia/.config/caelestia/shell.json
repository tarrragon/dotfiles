{
    "bar": {
        "persistent": true,
        "workspaces": {
            "shown": 9
        },
        "clock": {
            "format": "%H:%M"
        }
    },
    "notifs": {
        "expiration": 8000
    },
    "services": {
        "time": {
            "format24h": true
        }
    },
    "general": {
        "idle": {
            "timeouts": [
                {
                    "timeout": 900,
                    "idleAction": "dpms off",
                    "returnAction": "dpms on"
                },
                {
                    "timeout": 7200,
                    "idleAction": "lock"
                }
            ],
            "lockBeforeSleep": true
        }
    }
}
